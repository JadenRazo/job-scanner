# Copy to .env and fill in real values. Never commit the real .env.

# Postgres — shared raizhost-db container, separate DB + role
JOBSCANNER_DB_PASSWORD=change-me

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=https://jobs.raizhost.com
BETTER_AUTH_TRUSTED_ORIGINS=https://jobs.raizhost.com

# First-boot admin user (seeded once; rotate password after first login)
ADMIN_BOOTSTRAP_EMAIL=jaden@raizhost.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-strong

# LLM — all calls go through the Claude Code CLI (`claude -p`) against the
# host's Max subscription. No API key. Host ~/.claude/.credentials.json is
# bind-mounted into the worker container by docker-compose.yml.
CHEAP_MODEL=haiku
DEEP_MODEL=sonnet
# Hard ceiling on LLM calls in any rolling 5h window. Max 5x is ~225 msgs/5h;
# 30 gives ~7x headroom for Jaden's own interactive Claude use from the host.
LLM_MAX_CALLS_PER_5H=30
# Human-pacing jitter before every CLI call. Range looks like someone reading
# each response before sending the next prompt.
LLM_JITTER_MIN_MS=8000
LLM_JITTER_MAX_MS=45000
# Stage 2 batches this many JDs per Haiku call — the key to staying under cap.
STAGE2_BATCH_SIZE=15

# Discord notifications
DISCORD_WEBHOOK_URL=

# Scraper politeness
USER_AGENT=raizhost-job-scanner bot - jaden@raizhost.com
