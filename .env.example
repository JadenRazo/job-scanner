# Copy to .env and fill in real values. Never commit the real .env.
#
# All values below are placeholders. Replace with real secrets generated
# locally — the k3s deployment reads sealed secrets from raizhost-infra,
# not from this file. This file exists only as a schema reference for
# local docker-compose development.

# --- Postgres (shared raizhost-db, separate DB + role) ---
# Generate: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
JOBSCANNER_DB_PASSWORD=

# --- Better Auth ---
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://jobs.raizhost.com
BETTER_AUTH_TRUSTED_ORIGINS=https://jobs.raizhost.com

# --- LLM ---
# All calls go through the Claude Code CLI against the host's Max
# subscription. No API key. Host ~/.claude/.credentials.json is
# bind-mounted into the worker container by docker-compose.yml.
CHEAP_MODEL=haiku
DEEP_MODEL=sonnet
LLM_MAX_CALLS_PER_5H=30
LLM_JITTER_MIN_MS=8000
LLM_JITTER_MAX_MS=45000
STAGE2_BATCH_SIZE=15

# --- Discord notifications ---
# Paste your webhook URL here. Never commit it.
DISCORD_WEBHOOK_URL=

# --- Scraper politeness ---
USER_AGENT=

# --- Admin bootstrap (first-boot only) ---
# These are intentionally omitted from this example. To seed a first admin,
# set them in your local .env temporarily, let the app create the user on
# first /login hit, then delete them from .env and restart the container.
# See: src/lib/bootstrap.ts for the exact behaviour.
